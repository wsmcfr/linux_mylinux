# SPDX-License-Identifier: GPL-2.0
#
# 正点原子 STM32MP157D-ATK UVC USB 摄像头和 GPU 配置片段。
# 使用示例：scripts/kconfig/merge_config.sh .config arch/arm/configs/stm32mp157d_atk_uvc_gpu.config
# 合并后再执行 make ARCH=arm CROSS_COMPILE=<交叉编译器前缀> olddefconfig 生成最终 .config。
#
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_CAMERA_SUPPORT=y
CONFIG_VIDEO_DEV=y
CONFIG_VIDEO_V4L2=y
CONFIG_MEDIA_USB_SUPPORT=y
CONFIG_USB_VIDEO_CLASS=y
CONFIG_USB_VIDEO_CLASS_INPUT_EVDEV=y
CONFIG_VIDEOBUF2_CORE=y
CONFIG_VIDEOBUF2_V4L2=y
CONFIG_VIDEOBUF2_MEMOPS=y
CONFIG_VIDEOBUF2_VMALLOC=y
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_FUSB302=y
CONFIG_TYPEC_STUSB=y
CONFIG_USB_ROLE_SWITCH=y
CONFIG_GPU_GALCORE=m
