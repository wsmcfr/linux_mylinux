/dts-v1/;

#include "stm32mp157.dtsi"
#include "stm32mp15xd.dtsi"
#include "stm32mp15-pinctrl.dtsi"
#include "stm32mp15xxaa-pinctrl.dtsi"
#include "stm32mp157-m4-srm.dtsi"
#include "stm32mp157-m4-srm-pinctrl.dtsi"
#include "stm32mp157d-atk.dtsi"
#include <dt-bindings/input/input.h>
/ {
	model = "STMicroelectronics STM32MP157D eval daughter";
	compatible = "st,stm32mp157d-ed1", "st,stm32mp157";

	chosen {
		stdout-path = "serial0:115200n8";
	};

	aliases {
		serial0 = &uart4;
	};

	reserved-memory {
		gpu_reserved: gpu@f6000000 {
			reg = <0xf6000000 0x8000000>;
			no-map;
		};

		optee_memory: optee@fe000000 {
			reg = <0xfe000000 0x02000000>;
			no-map;
		};
	};
	
/*
	led {
		compatible = "atk,led";          
		pinctrl-names = "default";
		led-gpios = <&gpioi 0 GPIO_ACTIVE_LOW>;
		status = "okay";
	};
*/
/*	gpioled {
		compatible = "alientek,led";
		pinctrl-names = "default";
		status = "okay";
		pinctrl-0 = <&led_pins_a>;
		led-gpio = <&gpioi 0 GPIO_ACTIVE_LOW>;
	};
	*/
	dtsleds {
		compatible = "gpio-leds";
		pinctrl-0 = <&led_pins_a>;

		led0 {
			label = "red";
			gpios = <&gpioi 0 GPIO_ACTIVE_LOW>;
			default-state = "off";
		};
		
		led1 {
			label = "green";
			gpios = <&gpiof 3 GPIO_ACTIVE_LOW>;
			default-state = "off";
		};
	};
	
	beep{
		compatible = "atk,beep";
		beep-gpios = <&gpioc 7 GPIO_ACTIVE_HIGH>;
		status = "okay";
	};

	/*
	 * 使用 Linux 内核通用 gpio-keys 驱动注册三路按键。
	 * KEY0/KEY1 为低电平有效，WK_UP 为高电平有效并作为唤醒源。
	 */
	gpio_keys: gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&key_pins_a>;
		autorepeat;
		status = "okay";

		key0 {
			label = "GPIO Key L";
			linux,code = <KEY_L>;
			gpios = <&gpiog 3 GPIO_ACTIVE_LOW>;
			debounce-interval = <15>;
		};

		key1 {
			label = "GPIO Key S";
			linux,code = <KEY_S>;
			gpios = <&gpioh 7 GPIO_ACTIVE_LOW>;
			debounce-interval = <15>;
		};

		wkup {
			label = "GPIO Key Enter";
			linux,code = <KEY_ENTER>;
			gpios = <&gpioa 0 GPIO_ACTIVE_HIGH>;
			debounce-interval = <15>;
			wakeup-source;
		};
	};
};

&cpu1{
	cpu-supply = <&vddcore>;
};

&gpu {
	contiguous-area = <&gpu_reserved>;
	status = "okay";
};

&optee {
	status = "okay";
};
